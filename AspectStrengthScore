import React from 'react';
import { Card } from '@/components/ui/card';
import { Progress } from '@/components/ui/progress';
import { Badge } from '@/components/ui/badge';
import { AlertCircle, CheckCircle2, Zap, TrendingUp } from 'lucide-react';

export interface StrengthScoreProps {
  score: number; // 0-10 scale
  maxScore?: number;
  label?: string;
  description?: string;
  showThresholds?: boolean;
  showDetails?: boolean;
  compact?: boolean;
  aspectName?: string;
  modifiers?: StrengthModifier[];
}

export interface StrengthModifier {
  name: string;
  value: number;
  type: 'positive' | 'negative' | 'neutral';
  description?: string;
}

export interface InterpretationThreshold {
  min: number;
  max: number;
  level: 'low' | 'medium' | 'high' | 'very-high';
  label: string;
  color: string;
  bgColor: string;
  icon: React.ReactNode;
  interpretation: string;
}

/**
 * Interpretation thresholds for astrological strength scores
 * Customizable based on aspect type
 */
export const DEFAULT_THRESHOLDS: InterpretationThreshold[] = [
  {
    min: 0,
    max: 3.5,
    level: 'low',
    label: 'Subtle Influence',
    color: 'text-slate-500',
    bgColor: 'bg-slate-50',
    icon: <AlertCircle className="w-4 h-4" />,
    interpretation: 'Minor influence; passing echo or background support'
  },
  {
    min: 3.5,
    max: 6.5,
    level: 'medium',
    label: 'Moderate Impact',
    color: 'text-amber-600',
    bgColor: 'bg-amber-50',
    icon: <TrendingUp className="w-4 h-4" />,
    interpretation: 'Noticeable influence; growth catalyst or learning opportunity'
  },
  {
    min: 6.5,
    max: 8.5,
    level: 'high',
    label: 'Strong Influence',
    color: 'text-orange-600',
    bgColor: 'bg-orange-50',
    icon: <Zap className="w-4 h-4" />,
    interpretation: 'Significant impact; major life theme or transformative force'
  },
  {
    min: 8.5,
    max: 10,
    level: 'very-high',
    label: 'Fated Connection',
    color: 'text-rose-600',
    bgColor: 'bg-rose-50',
    icon: <CheckCircle2 className="w-4 h-4" />,
    interpretation: 'Destiny-level influence; soul contract or profound transformation'
  }
];

/**
 * Get the appropriate threshold for a given score
 */
export function getThresholdForScore(score: number, thresholds = DEFAULT_THRESHOLDS): InterpretationThreshold {
  return thresholds.find(t => score >= t.min && score <= t.max) || thresholds[0];
}

/**
 * Get color based on score
 */
export function getScoreColor(score: number): string {
  if (score < 3.5) return 'from-slate-400 to-slate-500';
  if (score < 6.5) return 'from-amber-400 to-amber-500';
  if (score < 8.5) return 'from-orange-400 to-orange-500';
  return 'from-rose-400 to-rose-500';
}

/**
 * AspectStrengthScore Component
 * Displays astrological aspect strength with visual progress bar and interpretation
 */
export const AspectStrengthScore: React.FC<StrengthScoreProps> = ({
  score,
  maxScore = 10,
  label = 'Aspect Strength',
  description,
  showThresholds = true,
  showDetails = true,
  compact = false,
  aspectName,
  modifiers = []
}) => {
  const threshold = getThresholdForScore(score);
  const percentage = (score / maxScore) * 100;
  const colorGradient = getScoreColor(score);

  if (compact) {
    return (
      <div className="flex items-center gap-3">
        <div className="flex-1">
          <div className="flex justify-between items-center mb-1">
            <span className="text-sm font-medium text-foreground">{label}</span>
            <span className={`text-sm font-bold ${threshold.color}`}>
              {score.toFixed(1)}/{maxScore}
            </span>
          </div>
          <div className="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
            <div
              className={`h-full bg-gradient-to-r ${colorGradient} transition-all duration-300`}
              style={{ width: `${percentage}%` }}
            />
          </div>
        </div>
        <Badge variant="outline" className={`${threshold.color} whitespace-nowrap`}>
          {threshold.label}
        </Badge>
      </div>
    );
  }

  return (
    <Card className={`p-6 ${threshold.bgColor} border-l-4 ${
      threshold.level === 'low' ? 'border-l-slate-400' :
      threshold.level === 'medium' ? 'border-l-amber-400' :
      threshold.level === 'high' ? 'border-l-orange-400' :
      'border-l-rose-400'
    }`}>
      {/* Header */}
      <div className="mb-6">
        <div className="flex items-start justify-between mb-2">
          <div>
            <h3 className="text-lg font-semibold text-foreground">{label}</h3>
            {aspectName && (
              <p className="text-sm text-muted-foreground mt-1">{aspectName}</p>
            )}
          </div>
          <div className="text-right">
            <div className={`text-3xl font-bold ${threshold.color}`}>
              {score.toFixed(1)}
            </div>
            <div className="text-xs text-muted-foreground">out of {maxScore}</div>
          </div>
        </div>
        {description && (
          <p className="text-sm text-muted-foreground">{description}</p>
        )}
      </div>

      {/* Progress Bar */}
      <div className="mb-6">
        <div className="flex justify-between items-center mb-2">
          <span className="text-xs font-medium text-muted-foreground">Strength Level</span>
          <Badge className={`${threshold.color} bg-transparent border`}>
            {threshold.label}
          </Badge>
        </div>
        <div className="w-full h-3 bg-slate-200 rounded-full overflow-hidden shadow-inner">
          <div
            className={`h-full bg-gradient-to-r ${colorGradient} transition-all duration-300 shadow-md`}
            style={{ width: `${percentage}%` }}
          />
        </div>
      </div>

      {/* Threshold Indicators */}
      {showThresholds && (
        <div className="mb-6">
          <div className="text-xs font-medium text-muted-foreground mb-3">Interpretation Scale</div>
          <div className="grid grid-cols-4 gap-2">
            {DEFAULT_THRESHOLDS.map((t, idx) => (
              <div
                key={idx}
                className={`p-2 rounded-lg border-2 transition-all ${
                  score >= t.min && score <= t.max
                    ? `border-current ${t.bgColor}`
                    : 'border-slate-200 bg-slate-50'
                }`}
              >
                <div className={`text-xs font-semibold ${
                  score >= t.min && score <= t.max ? t.color : 'text-muted-foreground'
                }`}>
                  {t.label}
                </div>
                <div className="text-xs text-muted-foreground mt-1">
                  {t.min.toFixed(1)}-{t.max.toFixed(1)}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Interpretation */}
      <div className={`p-4 rounded-lg ${threshold.bgColor} border border-current/20 mb-6`}>
        <div className="flex gap-3">
          <div className={`flex-shrink-0 ${threshold.color}`}>
            {threshold.icon}
          </div>
          <div>
            <p className="text-sm font-semibold text-foreground mb-1">
              {threshold.label}
            </p>
            <p className="text-sm text-muted-foreground">
              {threshold.interpretation}
            </p>
          </div>
        </div>
      </div>

      {/* Modifiers Breakdown */}
      {showDetails && modifiers.length > 0 && (
        <div className="pt-4 border-t border-current/10">
          <h4 className="text-sm font-semibold text-foreground mb-3">Strength Modifiers</h4>
          <div className="space-y-2">
            {modifiers.map((modifier, idx) => (
              <div key={idx} className="flex items-center justify-between p-2 rounded-lg bg-background/50">
                <div className="flex-1">
                  <p className="text-sm font-medium text-foreground">{modifier.name}</p>
                  {modifier.description && (
                    <p className="text-xs text-muted-foreground">{modifier.description}</p>
                  )}
                </div>
                <div className={`text-sm font-bold ${
                  modifier.type === 'positive' ? 'text-green-600' :
                  modifier.type === 'negative' ? 'text-red-600' :
                  'text-slate-600'
                }`}>
                  {modifier.type === 'positive' ? '+' : ''}
                  {modifier.value.toFixed(1)}
                </div>
              </div>
            ))}
          </div>
          <div className="mt-3 p-2 rounded-lg bg-background/50 border-t border-current/10">
            <div className="flex justify-between items-center">
              <span className="text-sm font-semibold text-foreground">Total Score</span>
              <span className={`text-lg font-bold ${threshold.color}`}>
                {score.toFixed(1)}/{maxScore}
              </span>
            </div>
          </div>
        </div>
      )}
    </Card>
  );
};

export default AspectStrengthScore;
